{
  "name": "mcpkit-cli",
  "version": "0.1.0",
  "description": "The create-next-app for MCP servers. Scaffold, develop, validate, and ship production-ready Model Context Protocol servers in seconds.",
  "type": "module",
  "bin": {
    "mcpkit": "./dist/bin/mcpkit.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "open": "^11.0.0",
    "ora": "^8.1.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "vitest": "^3.0.4"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "mcp-cli",
    "cli",
    "scaffolding",
    "scaffold",
    "create-mcp",
    "development-tools",
    "ai",
    "llm",
    "agent",
    "tool-use",
    "stdio",
    "http-transport",
    "vscode",
    "claude",
    "cursor",
    "ai-tools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sraveshnandan/mcpkit.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/sraveshnandan/mcpkit/issues"
  },
  "homepage": "https://mcpkit.dev",
  "license": "MIT"
}
